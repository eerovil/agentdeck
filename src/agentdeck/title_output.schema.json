{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["titles"],
  "properties": {
    "titles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title"],
        "properties": {
          "id": {"type": "integer", "minimum": 0},
          "title": {"type": "string", "minLength": 1, "maxLength": 100}
        }
      }
    }
  }
}
