[Unit]
Description=agentdeck persistent Codex runtime
After=network-online.target

[Service]
WorkingDirectory=%h/agentdeck
ExecStart=%h/agentdeck/.venv/bin/agentdeck codex-runtime
Restart=on-failure
RestartSec=5
Environment=AGENTDECK_CONFIG=%h/.config/agentdeck/config.toml
RuntimeDirectory=agentdeck
RuntimeDirectoryMode=0700
KillMode=control-group

[Install]
WantedBy=default.target
